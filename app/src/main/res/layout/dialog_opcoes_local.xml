<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/space_4">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_adicionar_sublocal"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Adicionar sublocal"
        android:textAlignment="textStart"
        android:paddingStart="@dimen/space_4"
        android:paddingEnd="@dimen/space_4"
        app:icon="@drawable/ic_plus"
        app:iconGravity="start"
        app:iconTint="@color/add_color" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_renomear_local"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_2"
        android:text="Renomear"
        android:textAlignment="textStart"
        android:paddingStart="@dimen/space_4"
        android:paddingEnd="@dimen/space_4"
        app:icon="@drawable/ic_edit"
        app:iconGravity="start"
        app:iconTint="@color/edit_color" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_excluir_local"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_2"
        android:text="Excluir"
        android:textAlignment="textStart"
        android:paddingStart="@dimen/space_4"
        android:paddingEnd="@dimen/space_4"
        android:textColor="@color/delete_color"
        app:icon="@drawable/ic_delete"
        app:iconGravity="start"
        app:iconTint="@color/delete_color" />

</LinearLayout>
