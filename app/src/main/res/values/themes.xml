<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Caderneta" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorPrimaryDark">@color/primary_color</item>
        <item name="colorSecondary">@color/secondary_color</item>
        <item name="android:windowBackground">@color/background_color</item>
        <item name="android:textColor">@color/on_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="ButtonStyle" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@color/button_background_unselected</item>
        <item name="iconTint">@color/button_icon_unselected</item>
        <item name="strokeColor">@color/button_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="ButtonStyle.Selected">
        <item name="backgroundTint">@color/button_background_selected</item>
        <item name="iconTint">@color/button_icon_selected</item>
        <item name="strokeColor">@color/button_background_selected</item>
    </style>
</resources>
