<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Auto Backup do Google é best-effort. O export JSON via SAF é o mecanismo primário. -->
        <include domain="database" path="caderneta_database" />
        <include domain="sharedpref" path="backup_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="caderneta_database" />
        <include domain="sharedpref" path="backup_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
